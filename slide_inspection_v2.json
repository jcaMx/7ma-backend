          "object_id": "g369bbc18a25_2_63",
          "type": "TEXT_BOX",
          "text": "Take It to the Next Level"
        },
        {
          "object_id": "g369bbc18a25_2_64",
          "type": "TEXT_BOX",
          "text": "Discover how to guide, refine, and shape AI responses with expert precision."
        },
        {
          "object_id": "g369bbc18a25_2_73",
          "type": "ROUND_RECTANGLE",
          "text": "Play Audio"
        },
        {
          "object_id": "g369bbc18a25_2_74",
          "type": "IMAGE",
          "text": ""
        },
