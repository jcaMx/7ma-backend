    {
      "slide_index": 1,
      "slide_id": "g369bbc18a25_2_96",
      "elements": [
        {
          "object_id": "g369bbc18a25_2_97",
          "type": "TEXT_BOX",
          "text": "Welcome to \u000bSeven Moves Ahead"
        },
        {
          "object_id": "g369bbc18a25_2_98",
          "type": "TEXT_BOX",
          "text": "Discover how AI can amplify your impact\u2014one capability at a time."
        },
        {
          "object_id": "g36c4f10f800_2_30",
          "type": "IMAGE",
          "text": ""
        },
        {
          "object_id": "g3d16c9cd8cb_3_20",
          "type": "TEXT_BOX",
          "text": "2"
        }
      ]
    },
    {
      "slide_index": 2,
      "slide_id": "g36b72ac01aa_0_0",
      "elements": [
        {
          "object_id": "g36b72ac01aa_0_25",
          "type": "TEXT_BOX",
          "text": "Pacific Crest Retirement Advisors, a mid-sized, independent firm in Southern California, specializes in retirement planning, pension strategies, and long-term wealth management for individuals, families, and business owners. \nAs the firm grew, advisors wasted time searching disparate systems, manually creating plan summaries and coordinating follow-ups; inconsistent documentation and fragmented workflows strained operations.\nPartnering with Digital Mixology, the firm implemented AI-powered workflows to streamline information access, automate content creation, and improve team coordination\u2014producing faster turnaround, \u000bmore consistent client communication, and \u000bbetter-informed decisions."
        },
        {
          "object_id": "g36b72ac01aa_0_26",
          "type": "IMAGE",
          "text": ""
        },
        {
          "object_id": "g36b72ac01aa_0_27",
          "type": "ROUND_RECTANGLE",
          "text": "Play Audio"
        },
        {
          "object_id": "g36b72ac01aa_0_29",
          "type": "TEXT_BOX",
          "text": "Fictional\nProfile"
        },
        {
          "object_id": "g36c4f10f800_2_29",
          "type": "IMAGE",
          "text": ""
        },
        {
          "object_id": "g3d16c9cd8cb_3_1",
