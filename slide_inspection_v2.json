        }
      ]
    },
    {
      "slide_index": 19,
      "slide_id": "g369bbc18a25_2_36",
      "elements": [
        {
          "object_id": "g369bbc18a25_2_43",
          "type": "TEXT_BOX",
          "text": "Personalized Plan. \nReal Results."
        },
        {
          "object_id": "g369bbc18a25_2_44",
          "type": "TEXT_BOX",
          "text": "A quick discovery process that leads to fast wins with AI\u2014no guesswork required."
        },
        {
          "object_id": "g369bbc18a25_2_71",
          "type": "ROUND_RECTANGLE",
          "text": "Play Audio"
        },
        {
          "object_id": "g36bcd406a95_0_0",
          "type": "IMAGE",
          "text": ""
        },
        {
          "object_id": "g3d16c9cd8cb_3_29",
          "type": "TEXT_BOX",
          "text": "20"
        }
      ]
    },
    {
      "slide_index": 20,
      "slide_id": "g369bbc18a25_2_57",
      "elements": [
        {
          "object_id": "g369bbc18a25_2_58",
          "type": "TEXT_BOX",
          "text": "It\u2019s Not Prompt Engineering\u2014\nIt\u2019s Communication"
        },
        {
          "object_id": "g369bbc18a25_2_59",
          "type": "TEXT_BOX",
          "text": "Learn how to get better results by treating AI like a highly capable human assistant."
        },
        {
          "object_id": "g369bbc18a25_2_72",
          "type": "ROUND_RECTANGLE",
          "text": "Play Audio"
